[Unit]
Description=GAIA MediaPipe Vision
After=network.target
# Gestito da gaia-agent — NON abilitare con systemctl enable

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/gaia/mediapipe
EnvironmentFile=/etc/gaia/device.conf
EnvironmentFile=-/etc/gaia/mediapipe.conf
ExecStart=/opt/gaia/mediapipe/start.sh
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
