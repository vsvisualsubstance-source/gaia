[Unit]
Description=GAIA Agent — controller servizi Pi
After=network.target
Wants=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/gaia/agent
ExecStart=/opt/gaia/agent/start.sh
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
# MQTT_HOST non più hardcoded: l'agent lo trova via discovery (docs/discovery-protocol.md).
# Per forzare un host: decommenta la riga sotto (salta la discovery).
# Environment=MQTT_HOST=192.168.1.142

[Install]
WantedBy=multi-user.target
