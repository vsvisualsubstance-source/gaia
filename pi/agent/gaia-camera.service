[Unit]
Description=GAIA Camera Broker (shared-memory frame server)
After=network.target
# Gestito da gaia-agent come dipendenza di yolo/mediapipe — NON abilitare con systemctl enable

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/gaia/camera
EnvironmentFile=/etc/gaia/device.conf
EnvironmentFile=-/etc/gaia/camera.conf
ExecStart=/opt/gaia/camera/start.sh
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
