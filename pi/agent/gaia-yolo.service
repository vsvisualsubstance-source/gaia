[Unit]
Description=GAIA YOLO Vision
After=network.target
# Gestito da gaia-agent — NON abilitare con systemctl enable

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/gaia/yolo
EnvironmentFile=/etc/gaia/device.conf
EnvironmentFile=-/etc/gaia/yolo.conf
ExecStart=/opt/gaia/yolo/start.sh
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
