# GAIA MediaPipe Node — configurazione
# Copia in /etc/gaia/mediapipe.conf e modifica per ogni Raspberry Pi

# Venv da usare (lascia vuoto per usare ./venv locale)
# Esempio: MEDIAPIPE_VENV=/home/asemico/mediapipe_edge/venv
MEDIAPIPE_VENV=

# Nome della stanza/camera (usato come room ID nel brain)
CAMERA_NAME=ingresso1

# IP del broker MQTT (il miniPC con Node-RED)
MQTT_HOST=192.168.1.142
MQTT_PORT=1883

# Nota: la camera non viene più aperta direttamente da questo servizio — i
# frame arrivano dal broker condiviso gaia-camera (shared memory). L'indice
# webcam si configura in /etc/gaia/camera.conf, non più qui.

# Secondi tra una pubblicazione e l'altra
PUBLISH_INTERVAL=1.0

# Analizza 1 frame ogni N catturati (FaceMesh+Hands+Pose sono pesanti su Pi).
# 1 = ogni frame (default, come prima). Alza a 3-6 per ridurre CPU ~5-6x
# a scapito di una risposta leggermente più lenta.
FRAME_SKIP=1

# 1 = nessuna finestra (headless, per Pi senza monitor)
HEADLESS=1

# Topic MQTT (non cambiare salvo necessità)
TOPIC=gaia/mediapipe/pose
