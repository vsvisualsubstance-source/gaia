# GAIA YOLO Node — configurazione
# Copia in /etc/gaia/yolo.conf e modifica per ogni Raspberry Pi

# Nome della stanza/room (claim iniziale, poi il Device Registry può correggere)
NODE_ID=ingresso

# Localizzazione
LOCATION=casa
ZONE=citofono

# Nome camera
CAMERA_NAME=cam1

# Indice webcam (0 = prima USB)
CAMERA_INDEX=0

# Broker MQTT
MQTT_HOST=192.168.1.142
MQTT_PORT=1883

# Modello YOLO
YOLO_MODEL=models/yolo11n.pt

# Soglie
CONFIDENCE_THRESHOLD=0.40
SNAPSHOT_CONF_THRESHOLD=0.75

# Processing
FRAME_SKIP=6

# Timing
PERSON_TIMEOUT=3
EVENT_COOLDOWN_SEC=2
HEARTBEAT_INTERVAL=30
