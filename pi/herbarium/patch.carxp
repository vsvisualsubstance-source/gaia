&lt;par_bool name=&quot;enabled&quot; value=&quot;yes&quot; /&gt;
&lt;par name=&quot;volume&quot; value=&quot;96&quot; /&gt;
&lt;par name=&quot;panning&quot; value=&quot;64&quot; /&gt;
