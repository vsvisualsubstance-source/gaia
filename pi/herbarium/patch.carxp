 <!-- Yoshimi -->
 <Plugin>
  <Info>
   <Type>LV2</Type>
   <Name>Yoshimi (2)</Name>
   <URI>http://yoshimi.sourceforge.net/lv2_plugin</URI>
  </Info>

  <Data>
   <Active>Yes</Active>
   <ControlChannel>1</ControlChannel>
   <Options>0x3f0</Options>

   <CustomData>
    <Type>http://kxstudio.sf.net/ns/carla/property</Type>
    <Key>CarlaSkinIsCompacted</Key>
    <Value>false</Value>
   </CustomData>

   <CustomData>
    <Type>http://lv2plug.in/ns/ext/atom#String</Type>
    <Key>http://yoshimi.sourceforge.net/lv2_plugin#state</Key>
    <Value>
&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot;?&gt;
&lt;!DOCTYPE Yoshimi-data&gt;
